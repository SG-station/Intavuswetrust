# Tavus credentials — get these from https://platform.tavus.io
TAVUS_API_KEY=your_tavus_api_key_here

# Replica ID — visual avatar (Charlie / Nathan / your custom replica)
# Find it at: https://platform.tavus.io/replicas → "Copy Replica ID"
TAVUS_REPLICA_ID=rfe12d8b9597

# Persona ID — behaviour/prompt (we'll create a custom Alstom one later)
# Find it at: https://platform.tavus.io/personas → "Copy Persona ID"
TAVUS_PERSONA_ID=pdced222244b

# Server config
PORT=3001
CLIENT_ORIGIN=http://localhost:5173

# Optional: greeting message spoken by the avatar at the start of the conversation
TAVUS_GREETING=Welcome to the Alstom Innovation Station in Singapore. I'm your concierge. How can I help you today?
